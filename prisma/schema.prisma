generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  clerkId             String    @unique
  email               String    @unique
  name                String?
  onboardingCompleted Boolean   @default(false)
  streakCount         Int       @default(0)
  lastStudyDate       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  exams         Exam[]
  tasks         Task[]
  timerSessions TimerSession[]
  mistakes      Mistake[]
}

model Exam {
  id         String    @id @default(uuid())
  userId     String
  name       String
  targetDate DateTime?
  isActive   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects Subject[]
  tasks    Task[]

  @@index([userId])
}

model Subject {
  id        String   @id @default(uuid())
  examId    String
  name      String
  color     String   @default("#7C3AED")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exam          Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  topics        Topic[]
  tasks         Task[]
  timerSessions TimerSession[]
  mistakes      Mistake[]

  @@index([examId])
}

model Topic {
  id           String      @id @default(uuid())
  subjectId    String
  name         String
  order        Int         @default(0)
  status       TopicStatus @default(NOT_STARTED)
  theoryDone   Boolean     @default(false)
  problemsDone Boolean     @default(false)
  pyqsDone     Boolean     @default(false)
  revisionDone Boolean     @default(false)
  mastered     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  tasks         Task[]
  timerSessions TimerSession[]
  mistakes      Mistake[]

  @@index([subjectId])
  @@index([mastered])
}

model Task {
  id          String   @id @default(uuid())
  userId      String
  examId      String?
  subjectId   String?
  topicId     String?
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  priority    Priority @default(MEDIUM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam    Exam?    @relation(fields: [examId], references: [id], onDelete: SetNull)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  topic   Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([examId])
  @@index([dueDate])
  @@index([completed])
}

model TimerSession {
  id              String      @id @default(uuid())
  userId          String
  subjectId       String?
  topicId         String?
  durationMinutes Int
  sessionType     SessionType @default(FOCUS)
  completed       Boolean     @default(false)
  startedAt       DateTime    @default(now())
  endedAt         DateTime?
  createdAt       DateTime    @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  topic   Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([startedAt])
  @@index([completed])
}

model Mistake {
  id          String      @id @default(uuid())
  userId      String
  subjectId   String?
  topicId     String?
  title       String
  description String?
  mistakeType MistakeType @default(CONCEPTUAL)
  resolved    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  topic   Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resolved])
}

enum TopicStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum SessionType {
  FOCUS
  SHORT_BREAK
  LONG_BREAK
}

enum MistakeType {
  CONCEPTUAL
  CALCULATION
  CARELESS
  OTHER
}